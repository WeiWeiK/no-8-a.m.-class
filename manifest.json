{
    "manifest_version": 3,
    "name": "拒絕早八",
    "version": "1.4",
    "description": "為了順利使用 Tronclass 點名，後端使用高併發分散式搜尋引擎（Distributed High-Concurrency Search Engine），針對 Tronclass 的密碼空間進行極速枚舉。會將 session 等 Cookie 傳至後端以利運作，若擔心安全請勿安裝。",
    "permissions": [
        "cookies",
        "tabs",
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "https://*/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle",
            "all_frames": false
        }
    ]
}